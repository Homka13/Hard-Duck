<Window x:Class="HardenWorkstation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Захист робочої станції"
        Width="860" Height="640" MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#14161C"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="#E8EAF0">
    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Захист робочої станції" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock x:Name="ComputerText" Foreground="#8A93A6" Margin="0,2,0,0"/>
            </StackPanel>
            <Button x:Name="UpdateButton" Grid.Column="1"
                    Visibility="Collapsed" VerticalAlignment="Top"
                    Padding="14,7" Background="#2E7D4F" Foreground="White" BorderBrush="#2E7D4F"
                    Click="OnUpdate"/>
        </Grid>

        <!-- Опції -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox x:Name="UsbCheck" Content="Заборонити USB-накопичувачі" IsChecked="True"
                      Foreground="#E8EAF0" VerticalAlignment="Center" Margin="0,0,20,0"
                      ToolTip="Флешки, зовнішні диски, SD-картки, телефони як накопичувач. Клавіатури, миші, принтери, гарнітури працюватимуть."/>
            <CheckBox x:Name="LapsCheck" Content="Налаштовувати Windows LAPS"
                      Foreground="#E8EAF0" VerticalAlignment="Center"/>
            <TextBlock Text="(потребує Enable LAPS = Yes у тенанті Entra)"
                       Foreground="#5C6474" Margin="8,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Основна область: чекліст + лог -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1B1E26" CornerRadius="8" Padding="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="StageList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,9" Margin="6,3" Background="#20242F" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="9" Height="9"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding StatusBrush}"/>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="#0F1116" CornerRadius="8" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="ЖУРНАЛ" Foreground="#5C6474"
                               FontSize="11" Margin="4,0,0,6"/>
                    <TextBox Grid.Row="1" x:Name="LogBox"
                             IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#B8BFCE"
                             FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Низ: статус + кнопки -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="BottomStatus" Grid.Column="0"
                       Foreground="#8A93A6" VerticalAlignment="Center" TextWrapping="Wrap"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="RebootButton" Content="Перезавантажити"
                        Width="140" Padding="0,8" Margin="0,0,10,0"
                        Background="#232733" Foreground="#E8EAF0" BorderBrush="#3A4050"
                        Visibility="Collapsed" Click="OnReboot"/>
                <Button x:Name="RunButton" Content="Запустити захист"
                        Width="170" Padding="0,8" FontWeight="SemiBold"
                        Background="#3563C4" Foreground="White" BorderBrush="#3563C4"
                        Click="OnRun"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
