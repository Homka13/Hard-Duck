<Window x:Class="HardDuck.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Hard-Duck — Захист робочої станції"
        Width="880" Height="720" MinWidth="760" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource MaterialDesignBackground}"
        FontFamily="{StaticResource MaterialDesignFont}"
        Foreground="{StaticResource MaterialDesignBody}"
        TextElement.Foreground="{StaticResource MaterialDesignBody}"
        Icon="{StaticResource DuckIcon}">
    <Window.Resources>
        <Style x:Key="SmallSwitchToggle" TargetType="ToggleButton" BasedOn="{StaticResource MaterialDesignSwitchToggleButton}">
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.75" ScaleY="0.75"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Заголовок ── -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <!-- Neon duck logo -->
                <Viewbox Width="36" Height="36" Margin="0,0,10,0">
                    <Path Data="{StaticResource DuckGeometry}"
                          Fill="{StaticResource AccentBrush}"
                          Stroke="{StaticResource AccentBrush}"
                          StrokeThickness="1.5"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.Effect>
                            <DropShadowEffect Color="#FFB300" BlurRadius="8"
                                              ShadowDepth="0" Opacity="0.8"/>
                        </Path.Effect>
                    </Path>
                </Viewbox>
                <StackPanel>
                    <TextBlock Text="HARD-DUCK" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" FontFamily="Consolas"
                              />
                    <TextBlock x:Name="ComputerText"
                               Foreground="{StaticResource MaterialDesignBodyLight}"
                               FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
            <Button x:Name="UpdateButton" Grid.Column="1"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Visibility="Collapsed" VerticalAlignment="Top"
                    Foreground="{StaticResource StatusOkBrush}"
                    Click="OnUpdate">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Download" Width="16" Height="16"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="ОНОВИТИ"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ── Картка 1: Апаратна безпека ── -->
        <materialDesign:Card Grid.Row="1" Padding="20,16" Margin="0,0,0,10"
>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="ShieldLock" Width="15" Height="15"
                                             Foreground="{StaticResource AccentBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="АПАРАТНА БЕЗПЕКА" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
                <UniformGrid Grid.Row="1" Columns="3" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                        <ToggleButton x:Name="SecureBootToggle" IsChecked="True"
                                      Style="{StaticResource SmallSwitchToggle}"
                                      ToolTip="Перевіряє стан Secure Boot в UEFI"
                                      VerticalAlignment="Center"
                                      Checked="OnToggleChanged" Unchecked="OnToggleChanged"/>
                        <TextBlock Text="Secure Boot" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{StaticResource MaterialDesignBody}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                        <ToggleButton x:Name="BitLockerPinToggle"
                                      Style="{StaticResource SmallSwitchToggle}"
                                      ToolTip="TPM+PIN — PIN питається до входу при кожному вмиканні"
                                      VerticalAlignment="Center"
                                      Checked="OnToggleChanged" Unchecked="OnToggleChanged"/>
                        <TextBlock Text="BitLocker PIN" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{StaticResource MaterialDesignBody}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="BiosToggle" IsChecked="True"
                                      Style="{StaticResource SmallSwitchToggle}"
                                      ToolTip="Перевіряє пароль BIOS/UEFI через Lenovo WMI"
                                      VerticalAlignment="Center"
                                      Checked="OnToggleChanged" Unchecked="OnToggleChanged"/>
                        <TextBlock Text="Пароль BIOS/UEFI" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{StaticResource MaterialDesignBody}"/>
                    </StackPanel>
                </UniformGrid>
            </Grid>
        </materialDesign:Card>

        <!-- ── Картка 2: Контроль доступу ── -->
        <materialDesign:Card Grid.Row="2" Padding="20,16" Margin="0,0,0,10"
>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="AccountKey" Width="15" Height="15"
                                             Foreground="{StaticResource AccentBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="КОНТРОЛЬ ДОСТУПУ" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
                <UniformGrid Grid.Row="1" Columns="2" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                        <ToggleButton x:Name="UsbToggle" IsChecked="True"
                                      Style="{StaticResource SmallSwitchToggle}"
                                      ToolTip="Блокує флешки, зовнішні диски, SD-картки. HID пристрої працюють."
                                      VerticalAlignment="Center"
                                      Checked="OnToggleChanged" Unchecked="OnToggleChanged"/>
                        <TextBlock Text="Заборонити USB-накопичувачі" VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   Foreground="{StaticResource MaterialDesignBody}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="HardDuckToggle" IsChecked="True"
                                      Style="{StaticResource SmallSwitchToggle}"
                                      ToolTip="Пароль адміна + BitLocker recovery-ключ → Infisical"
                                      VerticalAlignment="Center"
                                      Checked="OnToggleChanged" Unchecked="OnToggleChanged"/>
                        <TextBlock Text="Hard-Duck: адмін + BitLocker → Infisical"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{StaticResource MaterialDesignBody}"/>
                    </StackPanel>
                </UniformGrid>
            </Grid>
        </materialDesign:Card>

        <!-- ── Картка 3: Відповідність системи ── -->
        <materialDesign:Card Grid.Row="3" Padding="20,16" Margin="0,0,0,10"
>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="ClipboardCheck" Width="15" Height="15"
                                             Foreground="{StaticResource AccentBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="ВІДПОВІДНІСТЬ СИСТЕМИ" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
                <UniformGrid Grid.Row="1" Columns="2" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                        <ToggleButton x:Name="LapsToggle"
                                      Style="{StaticResource SmallSwitchToggle}"
                                      ToolTip="Windows LAPS — потребує Enable LAPS = Yes в Entra"
                                      VerticalAlignment="Center"
                                      Checked="OnToggleChanged" Unchecked="OnToggleChanged"/>
                        <TextBlock Text="Windows LAPS" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{StaticResource MaterialDesignBody}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PowerSleep" Width="16" Height="16"
                                                 Foreground="{StaticResource MaterialDesignBodyLight}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Гібернація" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{StaticResource MaterialDesignBodyLight}"/>
                        <TextBlock Text="(завжди)" VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource MaterialDesignBodyLight}"/>
                    </StackPanel>
                </UniformGrid>
            </Grid>
        </materialDesign:Card>

        <!-- ── Консоль: чекліст + термінал ── -->
        <Grid Grid.Row="4" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <!-- Чекліст -->
            <materialDesign:Card Grid.Column="0"
>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="4">
                    <ItemsControl x:Name="StageList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,7" Margin="6,2"
                                        Background="{DynamicResource MaterialDesignCardBackground}"
                                        CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="{Binding StatusIcon}"
                                            Width="18" Height="18"
                                            VerticalAlignment="Center"
                                            Foreground="{Binding StatusBrush}"/>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       FontSize="13"/>
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </materialDesign:Card>

            <!-- Термінал -->
            <Border Grid.Column="2" Background="{StaticResource TerminalBackground}"
                    CornerRadius="6" Padding="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6,0,4">
                        <materialDesign:PackIcon Kind="Console" Width="13" Height="13"
                                                 Foreground="{StaticResource MaterialDesignBodyLight}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="ТЕРМІНАЛ"
                                   Foreground="{StaticResource MaterialDesignBodyLight}"
                                   FontSize="10"/>
                    </StackPanel>
                    <RichTextBox Grid.Row="1" x:Name="LogBox"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="Transparent" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="12"
                                 Foreground="{StaticResource TerminalForeground}">
                        <FlowDocument x:Name="LogDocument" PagePadding="6,0"
                                      FontFamily="Consolas" FontSize="12"/>
                    </RichTextBox>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Нижня панель: прогрес, кнопки ── -->
        <materialDesign:Card Grid.Row="5" Margin="0,14,0,0" Padding="12,8"
>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ProgressBar Grid.Column="0" x:Name="RunProgress"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"
                             IsIndeterminate="False" Visibility="Collapsed"
                             Width="180" VerticalAlignment="Center" Margin="0,0,12,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon x:Name="StatusLockIcon" Kind="LockOutline"
                                             Width="14" Height="14"
                                             Foreground="{StaticResource MaterialDesignBodyLight}"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="BottomStatus"
                               Foreground="{StaticResource MaterialDesignBodyLight}"
                               VerticalAlignment="Center" TextWrapping="Wrap"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="RebootButton"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{StaticResource MaterialDesignBodyLight}"
                            Visibility="Collapsed" Click="OnReboot"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Restart" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="ПЕРЕЗАВАНТАЖИТИ"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="RunButton"
                            Style="{StaticResource MaterialDesignFloatingActionButton}"
                            ToolTip="Запустити захист"
                            Width="56" Height="56"
                            Click="OnRun">
                        <materialDesign:PackIcon x:Name="RunFabIcon"
                            Kind="ShieldCheck" Width="28" Height="28"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>
