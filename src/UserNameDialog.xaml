<Window x:Class="HardenWorkstation.UserNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ім'я користувача"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1B1E26"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="#E8EAF0">
    <StackPanel Margin="24,20,24,20">
        <TextBlock Text="Кому повернути права адміністратора?"
                   FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Text="Локальне ім'я користувача на цій машині (без домену)."
                   Foreground="#8A93A6" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <TextBox x:Name="NameBox" Padding="8,7" Background="#232733" BorderBrush="#3A4050"
                 Foreground="#E8EAF0" CaretBrush="#E8EAF0" TextChanged="OnChanged"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Скасувати" Width="100" Padding="0,7" Margin="0,0,10,0"
                    Background="#232733" Foreground="#E8EAF0" BorderBrush="#3A4050"
                    Click="OnCancel"/>
            <Button x:Name="OkButton" Content="Повернути права" Width="140" Padding="0,7"
                    Background="#3563C4" Foreground="White" BorderBrush="#3563C4"
                    IsEnabled="False" Click="OnOk"/>
        </StackPanel>
    </StackPanel>
</Window>
