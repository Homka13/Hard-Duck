<Window x:Class="HardDuck.PinDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PIN для BitLocker"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1B1E26"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="#E8EAF0">
    <StackPanel Margin="24,20,24,20">
        <TextBlock Text="Придумайте PIN для входу в BitLocker"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock x:Name="RulesText"
                   Foreground="#8A93A6" TextWrapping="Wrap" Margin="0,0,0,14"/>

        <TextBlock Text="PIN" Foreground="#8A93A6" Margin="0,0,0,4"/>
        <PasswordBox x:Name="Pin1" Padding="8,7" Background="#232733" BorderBrush="#3A4050"
                     Foreground="#E8EAF0" CaretBrush="#E8EAF0" PasswordChanged="OnPinChanged"/>

        <TextBlock Text="Повторіть PIN" Foreground="#8A93A6" Margin="0,12,0,4"/>
        <PasswordBox x:Name="Pin2" Padding="8,7" Background="#232733" BorderBrush="#3A4050"
                     Foreground="#E8EAF0" CaretBrush="#E8EAF0" PasswordChanged="OnPinChanged"/>

        <TextBlock x:Name="ErrorText" Foreground="#E09A2B" TextWrapping="Wrap"
                   Margin="0,10,0,0" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Скасувати" Width="100" Padding="0,7" Margin="0,0,10,0"
                    Background="#232733" Foreground="#E8EAF0" BorderBrush="#3A4050"
                    Click="OnCancel"/>
            <Button x:Name="OkButton" Content="Встановити PIN" Width="130" Padding="0,7"
                    Background="#3563C4" Foreground="White" BorderBrush="#3563C4"
                    IsEnabled="False" Click="OnOk"/>
        </StackPanel>
    </StackPanel>
</Window>
